# Copy this file to .env and fill in your values.
# Never commit .env — it is gitignored.

# EC2 instance ID of the t3.large harness box
HARNESS_INSTANCE_ID=i-0abc1234567890def
# AWS credentials must allow ssm:SendCommand and ssm:GetCommandInvocation on the harness instance.
# The harness EC2 instance must have an IAM instance profile with AmazonSSMManagedInstanceCore.

# S3 bucket name for result storage
S3_BUCKET=llm-eval-results

# AWS region (default: eu-central-1)
AWS_REGION=eu-central-1

# AWS credentials — remove these three lines if you are using ~/.aws/credentials,
# ~/.aws/config, or an IAM instance profile. If kept, these take precedence over
# credential files. To use a named profile instead, remove the three keys below
# and set AWS_PROFILE=<profile-name>.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# Endpoint for the model server — required for `python cli.py run-local`
# Set to http://localhost:11434 when using the local Ollama server (see local/README.md)
# Set to the model's EC2 instance private IPv4 address when using AWS
# In both cases, do not use the OpenAI-compatible API endpoint with `/v1` appended
MODEL_ENDPOINT_URL=http://localhost:11434
