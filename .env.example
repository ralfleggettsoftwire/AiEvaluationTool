# Copy this file to .env and fill in your values.
# Never commit .env — it is gitignored.

# EC2 instance ID of the t3.large harness box
HARNESS_INSTANCE_ID=i-0abc1234567890def

# SSH access to the harness instance (populated after `python cli.py start`)
HARNESS_SSH_HOST=54.12.34.56
HARNESS_SSH_USER=ec2-user
HARNESS_SSH_KEY_PATH=~/.ssh/harness-key.pem

# S3 bucket for result storage
S3_BUCKET=my-llm-eval-results

# AWS region (default: eu-west-1)
AWS_REGION=eu-west-1
